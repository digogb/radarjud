# DJE Monitor - Configurações
# Copie este arquivo para .env e ajuste os valores

# Tribunal principal
DJE_TRIBUNAL=TJCE

# CPFs para monitorar (separados por vírgula, apenas números)
DJE_CPFS_MONITORADOS=00000000000

# Fontes de dados
DJE_USAR_DJEN=true
DJE_USAR_ESAJ=true

# Scraping
DJE_REQUEST_TIMEOUT=60
DJE_DELAY_REQUISICOES=1.5
DJE_DIAS_RETROATIVOS=3
DJE_MAX_RETRIES=3

# Scheduler
DJE_MODO_SCHEDULER=false
DJE_HORA_EXECUCAO=7

# OCR
DJE_OCR_LANG=por
DJE_OCR_DPI=200

# Matcher
DJE_CONTEXTO_CHARS=500

# Telegram (opcional)
DJE_TELEGRAM_BOT_TOKEN=
DJE_TELEGRAM_CHAT_ID=

# Email SMTP (opcional)
DJE_SMTP_HOST=
DJE_SMTP_PORT=587
DJE_SMTP_USER=
DJE_SMTP_PASSWORD=
DJE_EMAIL_DESTINATARIOS=

# Banco de dados PostgreSQL
# DJE_DATABASE_URL=postgresql://dje:dje_secret@postgres:5432/dje_monitor

# Monitor de Pessoas
DJE_MONITOR_HABILITADO=true
DJE_MONITOR_INTERVAL_MINUTES=30
DJE_MONITOR_MAX_PAGINAS=10

# Redis (broker Dramatiq)
DJE_REDIS_URL=redis://redis:6379/0

# Worker
DJE_WORKER_THREADS=8
DJE_RATE_LIMIT_PER_SEC=2.0

# LLM + Embeddings (OpenAI) — obrigatório para busca semântica e resumos
DJE_OPENAI_API_KEY=
DJE_OPENAI_MODEL=gpt-4o-mini

# Busca Semântica (Qdrant)
# Provider padrão: OpenAI text-embedding-3-small (requer DJE_OPENAI_API_KEY, sem carga de RAM)
# Para usar modelo local (alto uso de RAM ~440MB): DJE_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
DJE_EMBEDDING_MODEL=text-embedding-3-small
DJE_EMBEDDING_DIMS=256

# Multi-Tenancy
# Chave secreta para API admin (/admin/tenants/*)
DJE_ADMIN_KEY=troque-por-chave-segura

# Ambiente (production | development)
# Em development, o middleware aceita ?tenant= como query param
DJE_ENVIRONMENT=production

# ===== Autenticação JWT =====
# Gerar com: openssl rand -hex 64
DJE_AUTH_JWT_SECRET=troque-por-secret-seguro-gerado-com-openssl-rand-hex-64

# Duração dos tokens (ajuste conforme necessário)
DJE_AUTH_ACCESS_EXPIRE_MINUTES=30
DJE_AUTH_REFRESH_EXPIRE_DAYS=30

# Proteção de conta
DJE_AUTH_MAX_LOGIN_ATTEMPTS=5
DJE_AUTH_LOCKOUT_MINUTES=15
DJE_AUTH_PASSWORD_MIN_LENGTH=8

# Rate limiting por IP no endpoint de login
DJE_AUTH_RATE_LIMIT_ATTEMPTS=20
DJE_AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# CORS — domínios adicionais permitidos (separados por vírgula)
# Ex: https://meuescritorio.radarjud.com.br
DJE_CORS_ORIGINS=
